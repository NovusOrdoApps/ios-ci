default_platform(:ios)

platform :ios do

  # ──────────────────────────────────────────────
  # setup_keychain
  # ──────────────────────────────────────────────
  lane :setup_keychain do
    create_keychain(
      name: "fastlane_ci",
      password: "ci",
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false,
      add_to_search_list: true,
    )
  end

  # ──────────────────────────────────────────────
  # install_profiles
  #
  # Usage: bundle exec fastlane install_profiles \
  #          type:appstore \
  #          app_identifiers:"com.foo.app,com.foo.app.widget"
  # ──────────────────────────────────────────────
  lane :install_profiles do |options|
    type = options[:type]
    ids = options[:app_identifiers].split(",")

    UI.user_error!("Missing 'type'") unless type
    UI.user_error!("Missing 'app_identifiers'") if ids.empty?

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_P8_PATH"),
    )

    match_opts = {
      type: type.to_s,
      api_key: api_key,
      app_identifier: ids,
      keychain_name: "fastlane_ci",
      keychain_password: "ci",
      readonly: false,
    }

    # Isolate each Apple team's certificates on its own branch in the match repo.
    # Match doesn't support multi-team in a single branch — its cert verification
    # treats every cert in the folder as belonging to the current team and
    # errors when it sees one that doesn't.
    #
    # Default: branch is "team-<IOS_RELEASE_TEAM_ID>". Override with MATCH_GIT_BRANCH.
    match_branch = ENV["MATCH_GIT_BRANCH"].to_s.strip
    if match_branch.empty?
      team_id = ENV["IOS_RELEASE_TEAM_ID"].to_s.strip
      match_branch = "team-#{team_id}" unless team_id.empty?
    end
    match_opts[:git_branch] = match_branch unless match_branch.empty?

    match_opts[:force_for_new_devices] = true if type.to_s == "adhoc"

    match(match_opts)
  end

  # ──────────────────────────────────────────────
  # set_signing
  #
  # Usage: bundle exec fastlane set_signing \
  #          type:appstore \
  #          targets_json:'[{"name":"Runner","bundle_id":"com.foo.app"}, ...]' \
  #          team_id:XXXXX \
  #          xcodeproj:Runner.xcodeproj
  # ──────────────────────────────────────────────
  lane :set_signing do |options|
    type = options[:type]
    team_id = options[:team_id]
    xcodeproj = options[:xcodeproj]
    targets = JSON.parse(options[:targets_json])

    match_type = type.to_s == "appstore" ? "AppStore" : "AdHoc"

    targets.each do |t|
      UI.message("Setting signing for target '#{t['name']}' → #{t['bundle_id']}")
      update_code_signing_settings(
        use_automatic_signing: false,
        team_id: team_id,
        targets: [t["name"]],
        profile_name: "match #{match_type} #{t['bundle_id']}",
        code_sign_identity: "Apple Distribution",
        bundle_identifier: t["bundle_id"],
        path: xcodeproj,
      )
    end
  end

  # ──────────────────────────────────────────────
  # upload_testflight_ipa
  # ──────────────────────────────────────────────
  lane :upload_testflight_ipa do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_P8_PATH"),
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: ENV.fetch("IPA_PATH"),
      skip_waiting_for_build_processing: true,
    )
  end

  # ──────────────────────────────────────────────
  # build_native
  #
  # Builds a non-Flutter Xcode project.
  # Usage: bundle exec fastlane build_native \
  #          workspace:App.xcworkspace \
  #          scheme:App \
  #          export_options:/path/to/ExportOptions.plist
  # ──────────────────────────────────────────────
  lane :build_native do |options|
    # build_app requires exactly ONE of workspace/project. Prefer workspace.
    # Workflow may pass "$GITHUB_WORKSPACE/" (repo root) when detection found no
    # workspace, so validate the actual value ends with .xcworkspace.
    workspace = options[:workspace].to_s.strip
    workspace = nil unless workspace.end_with?(".xcworkspace")

    project = options[:project].to_s.strip
    project = nil unless project.end_with?(".xcodeproj")

    if workspace.nil? && project.nil?
      UI.user_error!("Neither a .xcworkspace nor a .xcodeproj was provided to build_native.")
    end

    project = nil if workspace

    build_app(
      workspace: workspace,
      project: project,
      scheme: options[:scheme],
      configuration: options[:configuration].to_s.empty? ? "Release" : options[:configuration],
      export_options: options[:export_options],
      output_directory: "build/artifacts",
      output_name: "App.ipa",
      clean: true,
    )
  end

  # ──────────────────────────────────────────────
  # fetch_locales
  #
  # Queries App Store Connect for the app's active locales.
  # Writes a comma-separated list to GITHUB_OUTPUT or prints to stdout.
  # Usage: bundle exec fastlane fetch_locales
  # ──────────────────────────────────────────────
  lane :fetch_locales do
    require "spaceship"

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_P8_PATH"),
    )

    app = Spaceship::ConnectAPI::App.find(ENV.fetch("APP_BUNDLE_ID"))
    UI.user_error!("App not found: #{ENV.fetch('APP_BUNDLE_ID')}") unless app

    # Get the latest editable or live version to read its locales
    version = app.get_edit_app_store_version || app.get_live_app_store_version
    UI.user_error!("No app version found on App Store Connect.") unless version

    localizations = version.get_app_store_version_localizations
    locales = localizations.map(&:locale).sort

    UI.message(":: Found #{locales.size} locale(s): #{locales.join(', ')}")

    # Write to GITHUB_OUTPUT if available, otherwise print
    output_file = ENV["GITHUB_OUTPUT"]
    if output_file
      File.open(output_file, "a") { |f| f.puts("locales=#{locales.join(',')}") }
    else
      puts "LOCALES=#{locales.join(',')}"
    end
  end

  # ──────────────────────────────────────────────
  # fetch_screenshots
  #
  # Downloads screenshots from App Store Connect (latest live or editable version)
  # to disk in this structure:
  #   {output_path}/Screenshots/{locale}/{display_type}/01.png, 02.png, ...
  #
  # display_type uses Apple's actual constants (e.g. APP_IPHONE_67,
  # APP_IPAD_PRO_3GEN_129, APP_IPAD_PRO_3GEN_11).
  #
  # Usage: bundle exec fastlane fetch_screenshots output_path:/path/to/repo
  # ──────────────────────────────────────────────
  lane :fetch_screenshots do |options|
    require "spaceship"
    require "fileutils"
    require "open-uri"

    app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_P8_PATH"),
    )

    output_path = options[:output_path] || "."
    source = (options[:source] || "live").to_s  # "live" (default) or "edit"
    screenshots_dir = File.join(output_path, "Screenshots")
    FileUtils.mkdir_p(screenshots_dir)

    app = Spaceship::ConnectAPI::App.find(ENV.fetch("APP_BUNDLE_ID"))
    UI.user_error!("App not found: #{ENV.fetch('APP_BUNDLE_ID')}") unless app

    version =
      case source
      when "edit"
        app.get_edit_app_store_version || app.get_live_app_store_version
      when "live"
        app.get_live_app_store_version || app.get_edit_app_store_version
      else
        UI.user_error!("Invalid source '#{source}'. Use 'live' or 'edit'.")
      end
    UI.user_error!("No app version found on App Store Connect.") unless version

    UI.message(":: Fetching from version #{version.version_string} (state: #{version.app_store_state}, source preference: #{source})")

    localizations = version.get_app_store_version_localizations

    total_screenshots = 0

    localizations.each do |loc|
      locale = loc.locale
      screenshot_sets = loc.get_app_screenshot_sets(includes: "appScreenshots")

      if screenshot_sets.empty?
        UI.message(":: #{locale}: no screenshots")
        next
      end

      locale_count = 0

      screenshot_sets.each do |set|
        display_type = set.screenshot_display_type
        next if display_type.nil?

        screenshots = set.app_screenshots || []
        next if screenshots.empty?

        device_dir = File.join(screenshots_dir, locale, display_type)
        FileUtils.mkdir_p(device_dir)

        screenshots.each_with_index do |shot, idx|
          url = shot.image_asset_url(type: "png")
          unless url
            UI.important(":: #{locale}/#{display_type}: screenshot #{idx + 1} has no image_asset (skipping)")
            next
          end

          filename = format("%02d.png", idx + 1)
          out_path = File.join(device_dir, filename)

          URI.open(url) do |remote|
            File.binwrite(out_path, remote.read)
          end

          locale_count += 1
          total_screenshots += 1
        end
      end

      UI.message(":: #{locale}: #{locale_count} screenshot(s) downloaded")
    end

    UI.success("Downloaded #{total_screenshots} screenshot(s) across #{localizations.size} locale(s) to #{screenshots_dir}.")
  end

  # ──────────────────────────────────────────────
  # fetch_metadata
  #
  # Downloads metadata from App Store Connect via Spaceship,
  # writing each locale's fields to deliver-compatible format:
  #   {output_path}/metadata/{locale}/{field}.txt
  #
  # Usage: bundle exec fastlane fetch_metadata output_path:/tmp/asc-metadata
  # ──────────────────────────────────────────────
  lane :fetch_metadata do |options|
    require "spaceship"
    require "fileutils"

    app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_P8_PATH"),
    )

    output_path = options[:output_path] || "."
    source = (options[:source] || "live").to_s  # "live" (default) or "edit"
    metadata_dir = File.join(output_path, "metadata")
    FileUtils.mkdir_p(metadata_dir)

    app = Spaceship::ConnectAPI::App.find(ENV.fetch("APP_BUNDLE_ID"))
    UI.user_error!("App not found: #{ENV.fetch('APP_BUNDLE_ID')}") unless app

    version, app_info =
      case source
      when "edit"
        [app.get_edit_app_store_version || app.get_live_app_store_version,
         app.fetch_edit_app_info || app.fetch_live_app_info]
      when "live"
        [app.get_live_app_store_version || app.get_edit_app_store_version,
         app.fetch_live_app_info || app.fetch_edit_app_info]
      else
        UI.user_error!("Invalid source '#{source}'. Use 'live' or 'edit'.")
      end
    UI.user_error!("No app version found on App Store Connect.") unless version

    UI.message(":: Fetching from version #{version.version_string} (state: #{version.app_store_state}, source preference: #{source})")

    # Per-version localizations (description, keywords, marketing_url, promotional_text, support_url, whats_new)
    version_localizations = version.get_app_store_version_localizations
    app_info_by_locale = {}
    if app_info
      app_info.get_app_info_localizations.each do |info_loc|
        app_info_by_locale[info_loc.locale] = info_loc
      end
    end

    version_localizations.each do |loc|
      locale_dir = File.join(metadata_dir, loc.locale)
      FileUtils.mkdir_p(locale_dir)

      written = 0
      {
        "description.txt"      => loc.description,
        "keywords.txt"         => loc.keywords,
        "marketing_url.txt"    => loc.marketing_url,
        "promotional_text.txt" => loc.promotional_text,
        "support_url.txt"      => loc.support_url,
        "release_notes.txt"    => loc.whats_new,
      }.each do |filename, value|
        next if value.nil? || value.to_s.strip.empty?

        File.write(File.join(locale_dir, filename), value)
        written += 1
      end

      info_loc = app_info_by_locale[loc.locale]
      if info_loc
        {
          "name.txt"        => info_loc.name,
          "subtitle.txt"    => info_loc.subtitle,
          "privacy_url.txt" => info_loc.privacy_policy_url,
        }.each do |filename, value|
          next if value.nil? || value.to_s.strip.empty?

          File.write(File.join(locale_dir, filename), value)
          written += 1
        end
      end

      UI.message(":: #{loc.locale}: #{written} field(s) written")
    end

    UI.success("Downloaded metadata for #{version_localizations.size} locale(s) to #{metadata_dir}.")
  end

  # ──────────────────────────────────────────────
  # submit_for_review
  #
  # Auto-selects the latest editable version and latest TestFlight build,
  # then submits for review with automatic_release enabled.
  #
  # Requires: submission_info_path pointing to a submission.jsonc file with
  # answers to Apple's review questions.
  #
  # Usage: bundle exec fastlane submit_for_review \
  #          submission_info_path:/path/to/submission.jsonc
  # ──────────────────────────────────────────────
  lane :submit_for_review do |options|
    require "spaceship"
    require "json"

    submission_info_path = options[:submission_info_path]
    UI.user_error!("Missing submission_info_path") if submission_info_path.to_s.empty?
    UI.user_error!("Submission info file not found: #{submission_info_path}") unless File.exist?(submission_info_path)

    # Parse submission info (JSONC-compatible; strips // comments and trailing commas)
    raw = File.read(submission_info_path)
    raw = raw.delete_prefix("\xEF\xBB\xBF")
    raw = raw.gsub(%r{^\s*//.*$}, "").gsub(/,\s*([}\]])/, '\1')
    submission_info = JSON.parse(raw)

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_P8_PATH"),
    )

    app = Spaceship::ConnectAPI::App.find(ENV.fetch("APP_BUNDLE_ID"))
    UI.user_error!("App not found: #{ENV.fetch('APP_BUNDLE_ID')}") unless app

    # Find the current editable version
    version = app.get_edit_app_store_version
    UI.user_error!("No editable version found on App Store Connect. Create one via Update Metadata first.") unless version

    app_version = version.version_string
    UI.message(":: Editable version: #{app_version}")

    # Find latest build (sorted by upload date desc, limit 1)
    builds = Spaceship::ConnectAPI::Build.all(
      app_id: app.id,
      sort: "-uploadedDate",
      limit: 1,
    )
    UI.user_error!("No builds found in TestFlight for #{app.bundle_id}") if builds.empty?

    build = builds.first
    build_number = build.version
    UI.message(":: Latest TestFlight build: #{build_number}")

    deliver(
      api_key: api_key,
      app_identifier: ENV.fetch("APP_BUNDLE_ID"),
      app_version: app_version,
      build_number: build_number,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: true,
      force: true,
      submit_for_review: true,
      automatic_release: true,
      submission_information: submission_info,
      precheck_include_in_app_purchases: false,
    )

    UI.success("Submitted version #{app_version} (build #{build_number}) for review with automatic release.")
  end

  # ──────────────────────────────────────────────
  # update_metadata
  #
  # Uploads metadata and/or screenshots to App Store Connect.
  # Usage: bundle exec fastlane update_metadata \
  #          metadata_path:/tmp/deliver/metadata \
  #          screenshots_path:/tmp/deliver/screenshots \
  #          skip_screenshots:true \
  #          app_version:2.5.0
  # ──────────────────────────────────────────────
  lane :update_metadata do |options|
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_P8_PATH"),
    )

    deliver_opts = {
      api_key: api_key,
      app_identifier: ENV.fetch("APP_BUNDLE_ID"),
      metadata_path: options[:metadata_path],
      skip_binary_upload: true,
      force: true,
      precheck_include_in_app_purchases: false,
    }

    deliver_opts[:app_version] = options[:app_version] unless options[:app_version].to_s.empty?

    if options[:skip_screenshots] == "true"
      deliver_opts[:skip_screenshots] = true
    else
      deliver_opts[:skip_screenshots] = false
      deliver_opts[:screenshots_path] = options[:screenshots_path]
      deliver_opts[:overwrite_screenshots] = true
    end

    deliver(deliver_opts)
  end

end
