default_platform(:ios)

platform :ios do

  # ──────────────────────────────────────────────
  # setup_keychain
  # ──────────────────────────────────────────────
  lane :setup_keychain do
    create_keychain(
      name: "fastlane_ci",
      password: "ci",
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false,
      add_to_search_list: true,
    )
  end

  # ──────────────────────────────────────────────
  # install_profiles
  #
  # Usage: bundle exec fastlane install_profiles \
  #          type:appstore \
  #          app_identifiers:"com.foo.app,com.foo.app.widget"
  # ──────────────────────────────────────────────
  lane :install_profiles do |options|
    type = options[:type]
    ids = options[:app_identifiers].split(",")

    UI.user_error!("Missing 'type'") unless type
    UI.user_error!("Missing 'app_identifiers'") if ids.empty?

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_P8_PATH"),
    )

    match_opts = {
      type: type.to_s,
      api_key: api_key,
      app_identifier: ids,
      keychain_name: "fastlane_ci",
      keychain_password: "ci",
      readonly: false,
    }

    match_opts[:force_for_new_devices] = true if type.to_s == "adhoc"

    match(match_opts)
  end

  # ──────────────────────────────────────────────
  # set_signing
  #
  # Usage: bundle exec fastlane set_signing \
  #          type:appstore \
  #          targets_json:'[{"name":"Runner","bundle_id":"com.foo.app"}, ...]' \
  #          team_id:XXXXX \
  #          xcodeproj:Runner.xcodeproj
  # ──────────────────────────────────────────────
  lane :set_signing do |options|
    type = options[:type]
    team_id = options[:team_id]
    xcodeproj = options[:xcodeproj]
    targets = JSON.parse(options[:targets_json])

    match_type = type.to_s == "appstore" ? "AppStore" : "AdHoc"

    targets.each do |t|
      UI.message("Setting signing for target '#{t['name']}' → #{t['bundle_id']}")
      update_code_signing_settings(
        use_automatic_signing: false,
        team_id: team_id,
        targets: [t["name"]],
        profile_name: "match #{match_type} #{t['bundle_id']}",
        code_sign_identity: "Apple Distribution",
        bundle_identifier: t["bundle_id"],
        path: xcodeproj,
      )
    end
  end

  # ──────────────────────────────────────────────
  # upload_testflight_ipa
  # ──────────────────────────────────────────────
  lane :upload_testflight_ipa do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_P8_PATH"),
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: ENV.fetch("IPA_PATH"),
      skip_waiting_for_build_processing: true,
    )
  end

  # ──────────────────────────────────────────────
  # build_native
  #
  # Builds a non-Flutter Xcode project.
  # Usage: bundle exec fastlane build_native \
  #          workspace:App.xcworkspace \
  #          scheme:App \
  #          export_options:/path/to/ExportOptions.plist
  # ──────────────────────────────────────────────
  lane :build_native do |options|
    build_app(
      workspace: options[:workspace].to_s.empty? ? nil : options[:workspace],
      project: options[:project].to_s.empty? ? nil : options[:project],
      scheme: options[:scheme],
      configuration: options[:configuration].to_s.empty? ? "Release" : options[:configuration],
      export_options: options[:export_options],
      output_directory: "build/artifacts",
      output_name: "App.ipa",
      clean: true,
    )
  end

  # ──────────────────────────────────────────────
  # fetch_locales
  #
  # Queries App Store Connect for the app's active locales.
  # Writes a comma-separated list to GITHUB_OUTPUT or prints to stdout.
  # Usage: bundle exec fastlane fetch_locales
  # ──────────────────────────────────────────────
  lane :fetch_locales do
    require "spaceship"

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_P8_PATH"),
    )

    app = Spaceship::ConnectAPI::App.find(ENV.fetch("APP_BUNDLE_ID"))
    UI.user_error!("App not found: #{ENV.fetch('APP_BUNDLE_ID')}") unless app

    # Get the latest editable or live version to read its locales
    version = app.get_edit_app_store_version || app.get_live_app_store_version
    UI.user_error!("No app version found on App Store Connect.") unless version

    localizations = version.get_app_store_version_localizations
    locales = localizations.map(&:locale).sort

    UI.message(":: Found #{locales.size} locale(s): #{locales.join(', ')}")

    # Write to GITHUB_OUTPUT if available, otherwise print
    output_file = ENV["GITHUB_OUTPUT"]
    if output_file
      File.open(output_file, "a") { |f| f.puts("locales=#{locales.join(',')}") }
    else
      puts "LOCALES=#{locales.join(',')}"
    end
  end

  # ──────────────────────────────────────────────
  # update_metadata
  #
  # Uploads metadata and/or screenshots to App Store Connect.
  # Usage: bundle exec fastlane update_metadata \
  #          metadata_path:/tmp/deliver/metadata \
  #          screenshots_path:/tmp/deliver/screenshots \
  #          skip_screenshots:true \
  #          app_version:2.5.0
  # ──────────────────────────────────────────────
  lane :update_metadata do |options|
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_P8_PATH"),
    )

    deliver_opts = {
      api_key: api_key,
      app_identifier: ENV.fetch("APP_BUNDLE_ID"),
      metadata_path: options[:metadata_path],
      skip_binary_upload: true,
      force: true,
      precheck_include_in_app_purchases: false,
    }

    deliver_opts[:app_version] = options[:app_version] unless options[:app_version].to_s.empty?

    if options[:skip_screenshots] == "true"
      deliver_opts[:skip_screenshots] = true
    else
      deliver_opts[:skip_screenshots] = false
      deliver_opts[:screenshots_path] = options[:screenshots_path]
      deliver_opts[:overwrite_screenshots] = true
    end

    deliver(deliver_opts)
  end

end
